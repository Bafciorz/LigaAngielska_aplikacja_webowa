@model Liga.Web.Models.Player

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow-sm border-0 p-4">
        <h2 class="mb-3 text-primary">✏️ Edytuj dane zawodnika</h2>
        <p class="text-muted">Modyfikujesz profil zawodnika o ID: #@Model.PlayerId</p>
        <hr />
        
        <form method="post" action="/Players/Edit/@Model.PlayerId">
            <input type="hidden" name="PlayerId" value="@Model.PlayerId" />
            
            <div class="mb-3">
                <label class="form-label fw-bold">Imię</label>
                <input type="text" name="Name" value="@Model.Name" class="form-control" required />
            </div>
            
            <div class="mb-3">
                <label class="form-label fw-bold">Nazwisko</label>
                <input type="text" name="Surname" value="@Model.Surname" class="form-control" required />
            </div>
            
            <div class="mb-3">
                <label class="form-label fw-bold">Pozycja na boisku</label>
                <input type="text" name="pozycja" value="@Model.pozycja" class="form-control" required />
            </div>
            
            <div class="mb-4">
                <label class="form-label fw-bold">Przypisany Klub</label>
                <select name="TeamId" class="form-select" required>
                    @foreach (var team in ViewBag.Teams as List<Liga.Web.Models.Team>)
                    {
                        <option value="@team.TeamId" selected="@(team.TeamId == Model.TeamId ? "selected" : null)">
                            @team.Name
                        </option>
                    }
                </select>
            </div>
            
            <div class="d-flex justify-content-between">
                <button type="submit" class="btn btn-primary px-4">Zapisz zmiany</button>
                <a href="/Players/Index" class="btn btn-secondary px-4">Anuluj</a>
            </div>
        </form>
    </div>
</div>