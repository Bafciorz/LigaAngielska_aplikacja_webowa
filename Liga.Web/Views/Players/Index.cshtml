@model IEnumerable<Liga.Web.Models.Player>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🏃 Zawodnicy zarejestrowani w lidze</h2>
        <a href="/Players/Create" class="btn btn-primary">+ Dodaj nowego zawodnika</a>
    </div>

    <div class="card shadow-sm border-0 mt-3">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
            <tr>
                <th class="ps-4">Imię i Nazwisko</th>
                <th>Pozycja</th>
                <th>Klub</th>
                <th class="pe-4 text-end">Akcje</th> </tr>
            </thead>
            <tbody>
            @foreach (var player in Model)
            {
                <tr>
                    <td class="ps-4 align-middle"><strong>@player.Name @player.Surname</strong></td>
                    <td class="align-middle"><span class="badge bg-secondary">@player.pozycja</span></td>
                    <td class="align-middle fw-bold">@(player.Team != null ? player.Team.Name : "Wolny agent")</td>
                    <td class="pe-4 align-middle text-end">
                        <a href="/Players/Edit/@player.PlayerId" class="btn btn-outline-secondary btn-sm me-1">✏️ Edytuj</a>
                        <form method="post" action="/Players/Delete/@player.PlayerId" class="d-inline"
                              onsubmit="return confirm('Czy na pewno chcesz usunąć zawodnika @player.Name @player.Surname?');">
                            <button type="submit" class="btn btn-outline-danger btn-sm">🗑️ Usuń</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>