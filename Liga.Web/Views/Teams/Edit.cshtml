@model Liga.Web.Models.Team

<div class="container mt-4" style="max-width: 500px;">
    <div class="card shadow-sm border-0 p-4">
        <h3 class="text-primary mb-3">✏️ Edytuj dane klubu</h3>
        <p class="text-muted">Modyfikujesz klub o ID: #@Model.TeamId</p>
        <hr />
        
        <form method="post" action="/Teams/Edit/@Model.TeamId">
            <input type="hidden" name="TeamId" value="@Model.TeamId" />
            
            <div class="mb-3">
                <label class="form-label fw-bold">Nazwa klubu</label>
                <input type="text" name="Name" value="@Model.Name" class="form-control" required />
            </div>
            
            <div class="mb-4">
                <label class="form-label fw-bold">Zmień stadion domowy</label>
                <select name="StadiumId" class="form-select" required>
                    @foreach (var stadium in ViewBag.Stadiums as List<Liga.Web.Models.Stadium>)
                    {
                        <option value="@stadium.StadiumId" selected="@(stadium.StadiumId == Model.StadiumId ? "selected" : null)">
                            @stadium.Name (@stadium.City)
                        </option>
                    }
                </select>
            </div>
            
            <div class="d-flex justify-content-between">
                <button type="submit" class="btn btn-primary px-4">Zapisz zmiany</button>
                <a href="/Teams/Index" class="btn btn-secondary">Anuluj</a>
            </div>
        </form>
    </div>
</div>