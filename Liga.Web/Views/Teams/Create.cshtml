@model Liga.Web.Models.Team

<div class="container mt-4" style="max-width: 500px;">
    <div class="card shadow-sm border-0 p-4">
        <h3 class="text-success mb-3">⚽ Dodaj nową drużynę</h3>
        <p class="text-muted">Wprowadź nazwę klubu i przypisz mu oficjalny stadion domowy.</p>
        <hr />
        
        <form method="post" action="/Teams/Create">
            <div class="mb-3">
                <label class="form-label fw-bold">Nazwa klubu piłkarskiego</label>
                <input type="text" name="Name" class="form-control" placeholder="np. Chelsea FC" required />
            </div>
            
            <div class="mb-4">
                <label class="form-label fw-bold">Siedziba / Stadion domowy</label>
                <select name="StadiumId" class="form-select" required>
                    <option value="">-- Wybierz stadion z bazy --</option>
                    @foreach (var stadium in ViewBag.Stadiums as List<Liga.Web.Models.Stadium>)
                    {
                        <option value="@stadium.StadiumId">@stadium.Name (@stadium.City)</option>
                    }
                </select>
            </div>
            
            <div class="d-flex justify-content-between">
                <button type="submit" class="btn btn-success px-4">Zapisz klub</button>
                <a href="/Teams/Index" class="btn btn-secondary">Anuluj</a>
            </div>
        </form>
    </div>
</div>