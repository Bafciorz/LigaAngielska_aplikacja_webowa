<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Liga.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Liga.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Strona główna</a>
                    </li>
                    
                    @if (Context.Session.GetString("Username") != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/Stadiums/Index">🏟️ Stadiony</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/Teams/Index">⚽ Drużyny</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/Players/Index">🏃 Zawodnicy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/Matches/Index">🗓️ Mecze</a>
                        </li>
                    }
                    @if (Context.Session.GetString("Username") == "admin")
                    {
                        <li class="nav-item">
                            <a class="nav-link text-danger fw-bold" href="/Users/Index">🛡️ Zarządzaj użytkownikami</a>
                        </li>
                    }
                    
                </ul>

                <ul class="navbar-nav">
                    @if (Context.Session.GetString("Username") != null)
                    {
                        <li class="nav-item d-flex align-items-center me-3">
                            <span class="text-muted">Zalogowany jako: <strong>@Context.Session.GetString("Username")</strong></span>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-danger btn-sm" href="/IO/Wyloguj">Wyloguj się</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm" href="/IO/Logowanie">Zaloguj się</a>
                        </li>
                    }
                </ul>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Liga.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
