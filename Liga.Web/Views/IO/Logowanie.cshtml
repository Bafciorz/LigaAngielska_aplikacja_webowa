@{
    ViewData["Title"] = "Logowanie";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h3 class="card-title text-center mb-4">Zaloguj się</h3>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger" role="alert">
                        @ViewBag.Error
                    </div>
                }

                <form method="post" action="/IO/Logowanie">
                    
                    <div class="mb-3">
                        <label for="login" class="form-label">Login</label>
                        <input type="text" class="form-control" id="login" name="login" required>
                    </div>

                    <div class="mb-4">
                        <label for="haslo" class="form-label">Hasło</label>
                        <input type="password" class="form-control" id="haslo" name="haslo" required>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2">Zaloguj</button>
                </form>

            </div>
        </div>
    </div>
</div>