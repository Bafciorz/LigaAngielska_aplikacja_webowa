@model IEnumerable<Liga.Web.Models.PlayerStat>
@{
    var match = ViewBag.Match as Liga.Web.Models.Match;
    ViewData["Title"] = "Statystyki Meczowe";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📊 Szczegóły Spotkania</h2>
        <a href="/Matches/Index" class="btn btn-secondary">← Wróć do terminarza</a>
    </div>

    <div class="card bg-light shadow-sm border-0 mb-5 text-center">
        <div class="card-body py-4">
            <h6 class="text-muted text-uppercase fw-bold mb-3">🗓️ @match?.Date.ToString("dd MMMM yyyy - HH:mm")</h6>
            <div class="row align-items-center justify-content-center">
                <div class="col-md-4 text-end fs-3 fw-bold text-primary">@match?.HomeTeam?.Name</div>
                <div class="col-md-2">
                    <span class="badge bg-dark px-4 py-3 fs-2 shadow">
                        @match?.HomeGoals : @match?.AwayGoals
                    </span>
                </div>
                <div class="col-md-4 text-start fs-3 fw-bold text-danger">@match?.AwayTeam?.Name</div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>🏃 Statystyki indywidualne zawodników</h4>
        <a href="/PlayerStats/Create?matchId=@match?.MatchId" class="btn btn-success btn-sm">
            ➕ Dodaj statystykę gracza
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-striped table-hover text-center mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4 text-start">Zawodnik</th>
                        <th class="text-start">Klub</th>
                        <th>Minuty</th>
                        <th>Gole</th>
                        <th>Asysty</th>
                        <th>🟨</th>
                        <th>🟥</th>
                        <th class="pe-4 text-end">Akcje</th> </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">
                                Brak wprowadzonych statystyk dla tego meczu. Kliknij przycisk powyżej, aby dodać pierwsze!
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var stat in Model)
                        {
                            <tr>
                                <td class="ps-4 align-middle text-start fw-bold">
                                    @stat.Player?.Name @stat.Player?.Surname
                                </td>
                                <td class="align-middle text-start">
                                    <span class="small text-muted">@stat.Player?.Team?.Name</span>
                                </td>
                                <td class="align-middle">@stat.Minutes'</td>
                                <td class="align-middle">
                                    @if (stat.Goals > 0) { <span class="badge bg-success">⚽ @stat.Goals</span> } else { <span>0</span> }
                                </td>
                                <td class="align-middle">@stat.Assists</td>
                                <td class="align-middle">@stat.YellowCards</td>
                                <td class="align-middle">@stat.RedCards</td>
                                <td class="pe-4 align-middle text-end">
                                    <a href="/PlayerStats/Edit?matchId=@stat.MatchId&playerId=@stat.PlayerId" class="btn btn-outline-secondary btn-sm me-1">✏️</a>
                                    <form method="post" action="/PlayerStats/Delete?matchId=@stat.MatchId&playerId=@stat.PlayerId" class="d-inline"
                                          onsubmit="return confirm('Usunąć statystyki tego zawodnika z tego meczu?');">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">🗑️</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>