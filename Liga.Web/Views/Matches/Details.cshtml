@model IEnumerable<Liga.Web.Models.PlayerStat>
@{
    var match = ViewBag.Match as Liga.Web.Models.Match;
    ViewData["Title"] = "Statystyki Meczowe";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📊 Szczegóły Spotkania</h2>
        <a href="/Matches/Index" class="btn btn-secondary">← Wróć do terminarza</a>
    </div>

    <div class="card bg-light shadow-sm border-0 mb-5 text-center">
        <div class="card-body py-4">
            <h6 class="text-muted text-uppercase fw-bold mb-3">🗓️ @match?.Date.ToString("dd MMMM yyyy - HH:mm")</h6>
            <div class="row align-items-center justify-content-center">
                <div class="col-md-4 text-end fs-3 fw-bold text-primary">@match?.HomeTeam?.Name</div>
                <div class="col-md-2">
                    <span class="badge bg-dark px-4 py-3 fs-2 shadow">
                        @match?.HomeGoals : @match?.AwayGoals
                    </span>
                </div>
                <div class="col-md-4 text-start fs-3 fw-bold text-danger">@match?.AwayTeam?.Name</div>
            </div>
        </div>
    </div>

    <h4 class="mb-3">🏃 Statystyki indywidualne zawodników</h4>
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Zawodnik</th>
                        <th>Klub</th>
                        <th class="text-center">Rozegrane Minuty</th>
                        <th class="text-center">Gole</th>
                        <th class="text-center">Asysty</th>
                        <th class="text-center">Żółte kartki</th>
                        <th class="text-center pe-4">Czerwone kartki</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                Brak wprowadzonych statystyk zawodników dla tego meczu.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var stat in Model)
                        {
                            <tr>
                                <td class="ps-4 align-middle fw-bold">
                                    @stat.Player?.Name @stat.Player?.Surname
                                </td>
                                <td class="align-middle">
                                    <span class="small text-muted">@stat.Player?.Team?.Name</span>
                                </td>
                                <td class="text-center align-middle fw-bold">@stat.Minutes'</td>
                                <td class="text-center align-middle">
                                    @if (stat.Goals > 0)
                                    {
                                        <span class="badge bg-success px-2 py-1">⚽ @stat.Goals</span>
                                    }
                                        else { <span>0</span> }
                                </td>
                                <td class="text-center align-middle">@stat.Assists</td>
                                <td class="text-center align-middle">
                                    @if (stat.YellowCards > 0)
                                    {
                                        <span class="badge bg-warning text-dark">🟨 @stat.YellowCards</span>
                                    }
                                        else { <span>0</span> }
                                </td>
                                <td class="text-center align-middle pe-4">
                                    @if (stat.RedCards > 0)
                                    {
                                        <span class="badge bg-danger">🟥 @stat.RedCards</span>
                                    }
                                        else { <span>0</span> }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>