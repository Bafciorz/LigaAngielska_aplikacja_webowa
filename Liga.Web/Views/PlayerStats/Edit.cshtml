@model Liga.Web.Models.PlayerStat

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow-sm border-0 p-4">
        <h3 class="text-primary mb-2">✏️ Edytuj statystyki zawodnika</h3>
        <p class="text-muted fw-bold">Zawodnik: @Model.Player?.Name @Model.Player?.Surname</p>
        <hr />

        <form method="post" action="/PlayerStats/Edit">
            <input type="hidden" name="MatchId" value="@Model.MatchId" />
            <input type="hidden" name="PlayerId" value="@Model.PlayerId" />

            <div class="row mb-3">
                <div class="col">
                    <label class="form-label fw-bold">Rozegrane minuty</label>
                    <input type="number" name="Minutes" value="@Model.Minutes" class="form-control" min="0" max="120" required />
                </div>
                <div class="col">
                    <label class="form-label fw-bold">Strzelone gole</label>
                    <input type="number" name="Goals" value="@Model.Goals" class="form-control" min="0" required />
                </div>
            </div>

            <div class="row mb-4">
                <div class="col">
                    <label class="form-label fw-bold">Asysty</label>
                    <input type="number" name="Assists" value="@Model.Assists" class="form-control" min="0" required />
                </div>
                <div class="col">
                    <label class="form-label fw-bold">Żółte kartki (🟨)</label>
                    <input type="number" name="YellowCards" value="@Model.YellowCards" class="form-control" min="0" max="2" required />
                </div>
                <div class="col">
                    <label class="form-label fw-bold">Czerwone kartki (🟥)</label>
                    <input type="number" name="RedCards" value="@Model.RedCards" class="form-control" min="0" max="1" required />
                </div>
            </div>

            <div class="d-flex justify-content-between">
                <button type="submit" class="btn btn-primary px-4">Zapisz zmiany</button>
                <a href="/Matches/Details/@Model.MatchId" class="btn btn-secondary">Anuluj</a>
            </div>
        </form>
    </div>
</div>