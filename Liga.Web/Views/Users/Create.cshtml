@{
    ViewData["Title"] = "Nowy Użytkownik";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h4 class="card-title text-center mb-4">Stwórz nowego użytkownika</h4>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger" role="alert">
                        @ViewBag.Error
                    </div>
                }

                <form method="post" action="/Users/Create">
                    
                    <div class="mb-3">
                        <label for="username" class="form-label fw-bold">Login nowego użytkownika</label>
                        <input type="text" class="form-control" id="username" name="username" 
                               placeholder="np. jan_kowalski" required autocomplete="off">
                    </div>

                    <div class="mb-4">
                        <label for="password" class="form-label fw-bold">Hasło startowe</label>
                        <input type="password" class="form-control" id="password" name="password" 
                               placeholder="••••••••" required>
                        <div class="form-text text-muted">
                            Hasło zostanie automatycznie zabezpieczone algorytmem SHA-256 przed zapisem w bazie danych.
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a href="/Users/Index" class="text-decoration-none text-secondary">
                            ← Wróć do listy
                        </a>
                        <button type="submit" class="btn btn-primary px-4 py-2 shadow-sm">
                            Zapisz konto
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>