@model IEnumerable<Liga.Web.Models.User>

@{
    ViewData["Title"] = "Zarządzanie Użytkownikami";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark">🛡️ Panel Administratora: Użytkownicy</h2>
        <a href="/Users/Create" class="btn btn-success px-4 py-2 shadow-sm">
            + Dodaj użytkownika
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Nazwa użytkownika (Login)</th>
                            <th>Skrót hasła w bazie (SHA-256)</th>
                            <th class="pe-4 text-end">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4 align-middle">@user.Id</td>
                                <td class="align-middle">
                                    <span class="badge bg-light text-dark border px-3 py-2 fs-6">
                                        @user.Username
                                    </span>
                                </td>
                                <td class="align-middle text-muted" style="font-family: monospace; font-size: 0.85em;">
                                    @user.PasswordHash
                                </td>
                                <td class="pe-4 align-middle text-end">
                                    <form method="post" action="/Users/Delete/@user.Id" class="d-inline" 
                                          onsubmit="return confirm('Czy na pewno chcesz usunąć użytkownika @user.Username?');">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            🗑️ Usuń
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>